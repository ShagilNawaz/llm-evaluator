PORT=5000
MONGODB_URI=mongodb://localhost:27017/llm-evaluator
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
#  AI PROVIDER — pick ONE and fill in the corresponding key
# ─────────────────────────────────────────────────────────────

# OPTION 1: Groq (FREE — recommended for dev)
# Get key: https://console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OPTION 2: Google Gemini (FREE tier)
# Get key: https://aistudio.google.com/app/apikey
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIza_your_key_here
# GEMINI_MODEL=gemini-1.5-flash

# OPTION 3: Ollama (FREE — 100% local, no key needed)
# Install: https://ollama.com/download  then: ollama pull llama3.2
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OPTION 4: OpenRouter (FREE models available)
# Get key: https://openrouter.ai/keys
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-your_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# OPTION 5: Anthropic Claude (PAID — from $1/M tokens)
# Get key: https://console.anthropic.com
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
